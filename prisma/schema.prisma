generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Tier {
  bronze
  silver
  gold
  platinum
  diamond
}

enum MatchMode {
  ranked
  casual
  practice
  friend
}

enum RoomStatus {
  waiting
  active
  completed
  expired
}

enum Difficulty {
  easy
  mixed
  hard
}

model User {
  id               String   @id
  email            String   @unique
  name             String
  college          College? @relation(fields: [collegeId], references: [id])
  collegeId        String?
  rating           Int      @default(1000)
  tier             Tier     @default(bronze)
  isNewUser        Boolean  @default(true)
  collegeSelected  Boolean  @default(false)
  accuracy         Float    @default(0)
  totalMatches     Int      @default(0)
  wins             Int      @default(0)
  losses           Int      @default(0)
  bestStreak       Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  matchesAsP1      Match[]      @relation("Player1")
  matchesAsP2      Match[]      @relation("Player2")
  matchesWon       Match[]      @relation("Winner")
  roomsHosted      FriendRoom[] @relation("Host")
  roomsJoined      FriendRoom[] @relation("Guest")
}

model College {
  id       String  @id @default(uuid())
  name     String  @unique
  city     String
  state    String
  icon     String  @default("🏫")
  verified Boolean @default(true)
  users    User[]
}

model Match {
  id              String    @id @default(uuid())
  player1         User      @relation("Player1", fields: [player1Id], references: [id])
  player1Id       String
  player2         User      @relation("Player2", fields: [player2Id], references: [id])
  player2Id       String
  winner          User?     @relation("Winner", fields: [winnerId], references: [id])
  winnerId        String?
  mode            MatchMode
  roomCode        String?
  p1Score         Int       @default(0)
  p2Score         Int       @default(0)
  p1RatingChange  Int       @default(0)
  p2RatingChange  Int       @default(0)
  questions       Json
  p1Answers       Json      @default("[]")
  p2Answers       Json      @default("[]")
  durationSecs    Int       @default(0)
  createdAt       DateTime  @default(now())
}

model FriendRoom {
  id            String     @id @default(uuid())
  roomCode      String     @unique
  host          User       @relation("Host", fields: [hostId], references: [id])
  hostId        String
  guest         User?      @relation("Guest", fields: [guestId], references: [id])
  guestId       String?
  status        RoomStatus @default(waiting)
  questionCount Int        @default(10)
  difficulty    Difficulty @default(mixed)
  matchId       String?
  createdAt     DateTime   @default(now())
  expiresAt     DateTime
}

model CollegeRequest {
  id          String   @id @default(uuid())
  name        String
  city        String?
  requestedBy String
  createdAt   DateTime @default(now())
}